{
  "name": "@grx/engine",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev --config vite.demo.config.ts",
    "build": "vite build",
    "build:shaders": "node src/shaders/build.js",
    "build:shaders:watch": "node src/shaders/watch.js",
    "build:nc:types": "tsx src/data/importer/nc/parser/gen_dts_signature.js",
    "build:gerber:types": "tsx src/data/importer/gerber/parser/gen_dts_signature.js",
    "typecheck": "tsc --noEmit --watch",
    "test": "vitest run"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./data/shape/text/cozette/CozetteVector.ttf?url.js": {
      "default": "./dist/data/shape/text/cozette/CozetteVector.ttf?url.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@grx/parser-gdsii": "workspace:*",
    "@hpcreery/tracespace-parser": "^5.0.4",
    "@hpcreery/tracespace-plotter": "^5.0.3",
    "@hpcreery/tracespace-renderer": "^5.0.3",
    "@tracespace/parser": "^5.0.0-next.0",
    "@tracespace/plotter": "^5.0.0-alpha.0",
    "@types/unist": "^3.0.3",
    "chevrotain": "^12.0.0",
    "comlink": "^4.4.2",
    "dxf-parser": "^1.1.2",
    "earcut": "^3.0.2",
    "gl-matrix": "^3.4.4",
    "ndarray": "^1.0.19",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "regl": "^2.1.1",
    "typescript-event-target": "^1.1.1",
    "webgl-utils": "^1.0.1",
    "zod": "^4.1.12"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "devDependencies": {
    "chokidar": "^5.0.0",
    "vitest": "^4.0.18",
    "@mantine/core": "^9.0.1",
    "@mantine/hooks": "^9.0.1",
    "@grx/typescript-config": "workspace:*",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/earcut": "^3.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "glslify": "^7.1.1",
    "glslify-import": "^3.1.0",
    "rollup-plugin-glslify": "^1.3.1",
    "vite": "^7.3.2",
    "vite-plugin-arraybuffer": "^0.1.1",
    "vite-plugin-comlink": "^5.3.0",
    "vite-plugin-cross-origin-isolation": "^0.1.6",
    "vite-plugin-glsl": "^1.5.4"
  },
  "overrides": {
    "esbuild": "0.26.0"
  }
}
