{
  "extends": "@grx/typescript-config/vite.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "types": [
      "node",
    ],
    "paths": {
      "@src/*": [
        "./src/*"
      ],
    },
  },
  "include": [
    "src"
  ],
  "exclude": [
    "**/node_modules/**/*",
    "dist",
  ]
}