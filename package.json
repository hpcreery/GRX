{
  "name": "grx-turborepo",
  "version": "4.3.8",
  "description": "GPU-Accelerated Web Based EDA Manufacturing Artwork Viewer",
  "author": "Hunter Creery",
  "homepage": "https://github.com/hpcreery/GRX/blob/master/README.md",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "dev": "turbo watch dev",
    "dev:desktop": "turbo watch dev:desktop",
    "build": "turbo run build",
    "build:desktop": "turbo run build:desktop",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "check": "biome check --write",
    "typecheck": "turbo run typecheck",
    "changelog": "git-cliff --config cliff.toml --latest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.1",
    "commitlint": "^20.4.2",
    "git-cliff": "^2.12.0",
    "husky": "^9.1.7",
    "turbo": "2.9.9",
    "typescript": "6.0.3",
    "npm-check-updates": "^22.1.1"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
