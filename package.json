{
  "name": "grx-turborepo",
  "version": "4.3.2",
  "description": "GPU-Accelerated Web Based EDA Manufacturing Artwork Viewer",
  "author": "Hunter Creery",
  "homepage": "https://github.com/hpcreery/GRX/blob/master/README.md",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "dev": "turbo watch dev",
    "dev:desktop": "turbo watch dev:desktop",
    "build": "turbo run build",
    "build:desktop": "turbo run build:desktop",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "check": "biome check --write",
    "typecheck": "turbo run typecheck",
    "changelog": "git-cliff --config cliff.toml --latest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.1",
    "commitlint": "^20.4.2",
    "git-cliff": "^2.12.0",
    "husky": "^9.1.7",
    "turbo": "2.9.9",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.3+sha512.a19744364a7e248b92657a4ca5973f9354d21caf982579674b1c539f32c7420c47138ad8b1254df07aba9bc782d9b3029e3db34d5dbff974326eb74dac8ff489",
  "pnpm": {
    "overrides": {
      "esbuild": "0.26.0"
    },
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild",
      "phantomjs-prebuilt"
    ]
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
